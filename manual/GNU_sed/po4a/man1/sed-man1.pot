msgstr ""

#. type: TP
#: original/man1/sed.1:179
#, no-wrap
msgid "d"
msgstr ""

#. type: Plain text
#: original/man1/sed.1:183
msgid "Delete pattern space.  Start next cycle."
msgstr ""

#. type: TP
#: original/man1/sed.1:183
#, no-wrap
msgid "D"
msgstr ""

