msgstr ""

#. type: Plain text
#: original/man1/sed.1:172
msgid "Branch to I<label>; if I<label> is omitted, branch to end of script."
msgstr ""

#. type: TP
#: original/man1/sed.1:172
#, no-wrap
msgid "c \\e"
msgstr ""

#. type: Plain text
#: original/man1/sed.1:179
msgid ""
"Replace the selected lines with I<text>, which has each embedded newline "
