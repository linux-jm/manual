msgstr ""

#. type: Plain text
#: original/man1/lesskey.1:98
msgid ""
"\\ek followed by one or two characters represents the char(s) produced when "
"one of these keys is pressed:"
msgstr "\\ek の後に続く 1 文字または 2 文字は、これらのキーのいずれかを押したときに生成される文字を表します。"

#. type: tbl table
#: original/man1/lesskey.1:101
#, no-wrap
msgid "\\ekb"
msgstr ""

