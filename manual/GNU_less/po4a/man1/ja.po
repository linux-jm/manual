msgstr ""

#. type: tbl table
#: original/man1/lesskey.1:106 original/man1/lesskey.1:234
#, no-wrap
msgid "\\ekE"
msgstr ""

#. type: tbl table
#: original/man1/lesskey.1:106
#, no-wrap
msgid "ctrl-END"
msgstr ""

#. type: tbl table
#: original/man1/lesskey.1:107 original/man1/lesskey.1:235
#, no-wrap
msgid "\\ekF"
msgstr ""

#. type: tbl table
#: original/man1/lesskey.1:107
#, no-wrap
msgid "shift-END"
msgstr ""

#. type: tbl table
#: original/man1/lesskey.1:108 original/man1/lesskey.1:230
#: original/man1/lesskey.1:422
#, no-wrap
msgid "\\ekh"
